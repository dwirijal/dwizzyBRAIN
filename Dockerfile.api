FROM golang:1.24-bookworm AS builder

WORKDIR /src

COPY go.mod go.sum ./
COPY api ./api
COPY engine ./engine
COPY shared ./shared

RUN go build -trimpath -ldflags="-s -w" -o /out/dwizzyos-api ./api/cmd/api

FROM gcr.io/distroless/base-debian12

WORKDIR /

COPY --from=builder /out/dwizzyos-api /dwizzyos-api

EXPOSE 8080

USER nonroot:nonroot

ENTRYPOINT ["/dwizzyos-api"]
