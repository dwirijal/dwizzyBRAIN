{
  "openapi": "3.1.0",
  "info": {
    "title": "dwizzyBRAIN API",
    "version": "2.2.0",
    "description": "Unified gateway API for dwizzyOS content, auth, DeFi, and news services."
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "Local development"
    }
  ],
  "tags": [
    {
      "name": "Health",
      "description": "Service health checks"
    },
    {
      "name": "Content",
      "description": "Canonical media content read endpoints"
    },
    {
      "name": "Download",
      "description": "Capability-first wrapped download endpoints"
    },
    {
      "name": "Auth",
      "description": "Discord OAuth2, Web3 auth, sessions, and entitlements"
    },
    {
      "name": "DeFi",
      "description": "Public DeFi registry and snapshot endpoints"
    },
    {
      "name": "News",
      "description": "Public news feeds, trends, and article reads"
    }
  ],
