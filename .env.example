# Core runtime
API_PORT=8080
POSTGRES_URL=postgres://postgres:postgres@127.0.0.1:5432/dwizzy_media?sslmode=disable
# Optional compatibility fallback while local Postgres is being rolled out.
NEON_DATABASE_URL=
VALKEY_URL=redis://127.0.0.1:6379/0

# API content source
CONTENT_MANHWA_BASE_URL=
CONTENT_USER_AGENT=
# Backward-compatible aliases still supported by code.
MANHWAINDO_BASE_URL=
MANHWAINDO_USER_AGENT=

# API stalk wrapper
STALK_BASE_URL=
STALK_TIMEOUT=15s

# IRAG gateway
IRAG_PORT=8081
IRAG_TIMEOUT_MS=15s
IRAG_CACHE_ENABLED=true
IRAG_LOG_ENABLED=true
IRAG_ALLOWED_ORIGINS=*
IRAG_DEFAULT_CACHE_TTL=5m
IRAG_KANATA_URL=
IRAG_NEXURE_URL=
IRAG_RYZUMI_URL=
IRAG_CHOCOMILK_URL=
IRAG_YTDLP_URL=

# Auth + account
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_CLIENT_SECRET_FILE=
DISCORD_REDIRECT_URI=
JWT_SECRET=
JWT_SECRET_FILE=
AUTH_COOKIE_DOMAIN=.dwizzy.my.id
AUTH_FRONTEND_ORIGIN=https://dwizzy.my.id

# On-chain subscription resolver
# Preferred format: name|chain_id|rpc_url|contract_address[|method], separated by semicolons.
SUBSCRIPTION_NETWORKS="base|8453|https://mainnet.base.org|0x830F0317eA5005C581dCCf13193DB3f0c90270B2;bsc|56|https://bsc-dataseed.binance.org|0x8357e65F8223c2662F0eCde232F18B043E120159;kaia|8217|https://public-en.node.kaia.io|0x0Bd231DDFd5659278458696f784ce88CBa8Bae0e;arbitrum|42161|https://arb1.arbitrum.io/rpc|0x4d6B7628678B921F12646B023F44b3ea09889ce7"
SUBSCRIPTION_RPC_URL=
SUBSCRIPTION_MANAGER_ADDRESS=
SUBSCRIPTION_METHOD=isSubscribed
SUBSCRIPTION_CACHE_TTL=5m
